# AstroGuard MAS — Environment Variables
# Copy this file to .env and fill in your values.

# NASA NeoWs API Key (Near Earth Object Web Service)
# Get your free key at: https://api.nasa.gov/
NASA_API_KEY=PASTE_YOUR_KEY_HERE

# Ollama LLM Model
# Benchmarked: qwen2.5:7b (100/100), llama3.1 (100/100), phi3 (72.5/100)
OLLAMA_MODEL=qwen2.5:7b